#!/usr/bin/env bash
# codex-vault-build-indexes — build the metadata DB, FTS5, and (optionally) LanceDB
#
# Usage:
#   codex-vault-build-indexes --vault-root /path/to/codex-vault
#   codex-vault-build-indexes --vault-root /path/to/codex-vault --no-vector
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -d "$PKG_ROOT/src" ]]; then
  export PYTHONPATH="$PKG_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
fi

exec python3 -m codex_vault_pipeline.cli build-indexes "$@"
