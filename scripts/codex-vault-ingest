#!/usr/bin/env bash
# codex-vault-ingest — ingest a GitHub source into the vault
#
# Usage:
#   codex-vault-ingest --vault-root /path/to/codex-vault --github https://github.com/owner/repo
#   codex-vault-ingest --vault-root /path/to/codex-vault --github owner/repo --dry-run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -d "$PKG_ROOT/src" ]]; then
  export PYTHONPATH="$PKG_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
fi

exec python3 -m codex_vault_pipeline.cli ingest "$@"
